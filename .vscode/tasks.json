{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build (Mac)",
            "type": "shell",
            "command": "clang++",
            "args": [
                "-std=c++17",
                "-g",
                "${workspaceFolder}/src/*.cpp",
                "-I", "${workspaceFolder}/include",
                "-I", "/opt/homebrew/include",
                "-L", "/opt/homebrew/lib",
                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system",
                "-o", "${workspaceFolder}/build/game"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build (Windows)",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-g",
                "${workspaceFolder}/src/*.cpp",
                "-I", "${workspaceFolder}/include",
                "-I", "C:/SFML-3.1.0/include",
                "-L", "C:/SFML-3.1.0/lib",
                "-lsfml-graphics",
                "-lsfml-window",
                "-lsfml-system",
                "-o", "${workspaceFolder}/build/game.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}