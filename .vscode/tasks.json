{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build",
      "type": "shell",
      "command": "g++",
      "args": [
        "-g",
        "${workspaceFolder}/src/*.cpp",
        "-I", "C:/SFML-3.1.0/include",
        "-L", "C:/SFML-3.1.0/lib",
        "-lsfml-graphics",
        "-lsfml-window",
        "-lsfml-system",
        "-o",
        "${workspaceFolder}/build/game.exe"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}